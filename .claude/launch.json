{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "Node http-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "-p", "8001"],
      "port": 8001
    },
    {
      "name": "Node Live Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=8002"],
      "port": 8002
    }
  ]
}
